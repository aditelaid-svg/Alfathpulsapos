rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }

    function getUserData() {
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && 
             (request.auth.token.email == "aditelaid@gmail.com" || getUserData().role == 'admin');
    }

    function isAudit() {
      return isAuthenticated() && getUserData().role == 'audit';
    }

    function isEmployee() {
      return isAuthenticated() && getUserData().role == 'employee' && getUserData().isApproved == true;
    }

    function isApproved() {
      return isAdmin() || isAudit() || isEmployee();
    }

    function isBranchMember(branchId) {
      return isAdmin() || isAudit() || (isEmployee() && getUserData().branchId == branchId);
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /products/{productId} {
      allow read: if isApproved();
      allow write: if isAdmin(); // Bos only manages the catalog
    }

    match /branches/{branchId}/inventory/{itemId} {
      allow read: if isBranchMember(branchId);
      // Auditor can manage stock. Employees can only update (deduct) via POS or logs.
      allow write: if isAdmin() || isAudit() || (isEmployee() && getUserData().branchId == branchId);
    }

    // Collection Group rule for inventory queries across all branches (Admin/Audit only)
    match /{path=**}/inventory/{itemId} {
      allow read: if isAdmin() || isAudit();
    }

    match /branches/{branchId} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || isAudit() || (isEmployee() && resource.data.branchId == getUserData().branchId);
      allow create: if isEmployee();
    }

    match /transfers/{transferId} {
      allow read: if isAdmin() || isAudit();
      allow write: if isAdmin() || isAudit();
    }

    match /disposals/{disposalId} {
      allow read: if isAdmin() || isAudit();
      allow create: if isEmployee();
    }
    
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAdmin(); // Only Bos approves or changes roles
    }

    match /handovers/{handoverId} {
      allow read: if isAdmin();
      allow create: if isEmployee();
      allow delete: if isAdmin();
    }
  }
}

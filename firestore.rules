rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Hardened Helpers
    // ===============================================================
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }

    function isAdmin() { 
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    
    function isAudit() {
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'audit';
    }

    function isEmployee() {
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    function getUserBranchId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId;
    }

    // ===============================================================
    // Validation Helpers (Anti-Update-Gap)
    // ===============================================================
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 255 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ['admin', 'audit', 'employee'] &&
             data.isApproved is bool &&
             data.branchId is string;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.category in ['voucher', 'perdana', 'aksesoris'] &&
             data.provider is string && data.provider.size() <= 128 &&
             data.variants is list && data.variants.size() <= 50;
    }

    function isValidHandover(data) {
      return data.branchId is string &&
             data.employeeId == request.auth.uid &&
             data.employeeName is string &&
             data.shift in ['pagi', 'siang', 'malam'] &&
             data.totalVoucher is number &&
             data.totalAksesoris is number &&
             data.totalCalculated is number &&
             data.cashReported is number &&
             data.diff is number &&
             data.timestamp == request.time;
    }

    // ===============================================================
    // Fortress Rules
    // ===============================================================
    match /{document=**} { allow read, write: if false; }
    
    // Explicitly allow collectionGroup query for inventory search
    match /{path=**}/inventory/{itemId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
    }

    // Helper to check if user has access to a resource based on branch
    function hasBranchAccess(resourceBranchId) {
      return isAdmin() || isAudit() || (isEmployee() && resourceBranchId == getUserBranchId());
    }

    match /users/{userId} {
      allow read: if isVerified() && (request.auth.uid == userId || isAdmin() || isAudit() || isEmployee());
      allow create: if isValidId(userId) && isVerified() && request.auth.uid == userId && incoming().email == request.auth.token.email;
      allow update: if isValidId(userId) && isVerified() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email'])) || 
        isAdmin()
      );
    }

    match /products/{productId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create, update: if isValidId(productId) && isAdmin() && isValidProduct(incoming());
      allow delete: if isValidId(productId) && isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow write: if isValidId(branchId) && isAdmin();

      match /inventory/{itemId} {
        allow read: if isVerified() && hasBranchAccess(branchId);
        allow create, update, delete: if isVerified() && hasBranchAccess(branchId);
      }
    }

    match /active_shifts/{shiftId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create: if isVerified() && isEmployee() && incoming().employeeId == request.auth.uid;
      allow delete: if isVerified() && (isAdmin() || (isEmployee() && existing().employeeId == request.auth.uid));
    }

    match /handovers/{handoverId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create: if isVerified() && isEmployee() && isValidHandover(incoming());
      allow delete: if isAdmin();
    }

    match /disposals/{disposalId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create: if isVerified() && isEmployee() && incoming().branchId == getUserBranchId();
    }

    match /audit_logs/{logId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create: if isVerified() && (isAdmin() || isAudit() || isEmployee());
    }

    match /transactions/{transactionId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create: if isVerified() && isEmployee() && incoming().branchId == getUserBranchId() && incoming().employeeId == request.auth.uid && incoming().totalAmount > 0;
    }

    match /transfers/{transferId} {
      allow read: if isVerified() && (isAdmin() || isAudit() || isEmployee());
      allow create: if isVerified() && isEmployee() && incoming().fromBranchId == getUserBranchId();
    }
  }
}

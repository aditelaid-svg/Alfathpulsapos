rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Hardened Helpers
    // ===============================================================
    function isSignedIn() { return request.auth != null; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    
    function getUserData() {
       return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             (request.auth.token.email == "aditelaid@gmail.com" || 
             (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin'));
    }

    function isAudit() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'audit';
    }

    function isEmployee() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'employee' && getUserData().isApproved == true;
    }

    function isBranchMember(branchId) {
      return isAdmin() || isAudit() || (isEmployee() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().branchId == branchId);
    }
    
    // Schema Validator Helpers
    function isValidProduct(data) {
      return data.name is string && data.category is string && data.provider is string;
    }

    // ===============================================================
    // Fortress Rules
    // ===============================================================
    
    // Default Deny
    match /{document=**} { allow read, write: if false; }

    match /products/{productId} {
      allow read: if isSignedIn() && (isAdmin() || isAudit() || isEmployee());
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isSignedIn() && (isAdmin() || isAudit() || isEmployee());
      allow write: if isAdmin();
    }

    match /branches/{branchId}/inventory/{itemId} {
      allow read: if isBranchMember(branchId);
      
      // Kasir tidak boleh menulis langsung ke dokumen inventaris. 
      // Mereka hanya boleh lewat transaksi POS (via transaksi/transfers/disposals)
      allow write: if isAdmin() || isAudit();
    }

    match /transactions/{transactionId} {
      allow read: if isAdmin() || isAudit() || (isEmployee() && resource.data.branchId == getUserData().branchId);
      allow create: if isEmployee() && request.resource.data.branchId == getUserData().branchId;
    }

    match /transfers/{transferId} {
      allow read: if isAdmin() || isAudit();
      allow create: if isEmployee() || isAdmin();
    }

    match /disposals/{disposalId} {
      allow read: if isAdmin() || isAudit();
      allow create: if isEmployee();
    }
    
    match /users/{userId} {
      // Allow read if owner OR admin. 
      // Changed from isOwner() helper to explicit check to avoid potential get() calls on self in some contexts.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if (isOwner(userId) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /handovers/{handoverId} {
      allow read: if isAdmin() || isAudit() || (isEmployee() && resource.data.branchId == getUserData().branchId);
      allow create: if isEmployee();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin() || isAudit();
      allow create: if isAdmin() || isAudit() || isEmployee();
    }
  }
}

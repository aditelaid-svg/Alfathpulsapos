rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Hardened Helpers
    // ===============================================================
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }

    function isAdmin() { 
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; 
    }
    
    function isAudit() {
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'audit';
    }

    function isEmployee() {
      return isVerified() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'employee' && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isApproved == true;
    }

    function getUserBranchId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.branchId;
    }

    // ===============================================================
    // Validation Helpers (Anti-Update-Gap)
    // ===============================================================
    function isValidUser(data) {
      return data.email is string && data.email.size() <= 255 &&
             data.name is string && data.name.size() <= 128 &&
             data.role in ['admin', 'audit', 'employee'] &&
             data.isApproved is bool &&
             data.branchId is string;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 128 &&
             data.category in ['voucher', 'perdana', 'aksesoris'] &&
             data.provider is string && data.provider.size() <= 128 &&
             data.variants is list && data.variants.size() <= 50;
    }

    // ===============================================================
    // Fortress Rules
    // ===============================================================
    match /{document=**} { allow read, write: if false; }

    match /users/{userId} {
      allow read: if isValidId(userId) && isVerified() && (
        request.auth.uid == userId || isAdmin() || isAudit() || 
        (getUserBranchId() == resource.data.branchId)
      );
      allow create: if isValidId(userId) && isVerified() && request.auth.uid == userId && incoming().email == request.auth.token.email;
      allow update: if isValidId(userId) && isVerified() && (
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email'])) || 
        isAdmin()
      );
    }

    match /products/{productId} {
      allow read: if isValidId(productId) && isVerified();
      allow create, update: if isValidId(productId) && isAdmin() && isValidProduct(incoming());
      allow delete: if isValidId(productId) && isAdmin();
    }

    match /branches/{branchId} {
      allow read: if isValidId(branchId) && isVerified();
      allow write: if isValidId(branchId) && isAdmin();
    }

    match /branches/{branchId}/inventory/{itemId} {
      allow read: if isValidId(branchId) && isValidId(itemId) && isVerified() && (isAdmin() || isAudit() || getUserBranchId() == branchId);
      
      allow update: if isValidId(branchId) && isValidId(itemId) && isVerified() && (isAdmin() || isAudit() || (
        getUserBranchId() == branchId &&
        incoming().stock >= 0 &&
        incoming().stock < resource.data.stock // Strictly consumption/decrease
      ));
      
      allow create, delete: if isValidId(branchId) && isValidId(itemId) && (isAdmin() || isAudit());
    }

    match /transactions/{transactionId} {
      allow read: if isValidId(transactionId) && isVerified() && (isAdmin() || isAudit() || resource.data.branchId == getUserBranchId());
      
      allow create: if isValidId(transactionId) && isVerified() && isEmployee() && 
        incoming().branchId == getUserBranchId() &&
        incoming().employeeId == request.auth.uid &&
        incoming().totalAmount > 0;
    }

    match /transfers/{transferId} {
      allow read: if isValidId(transferId) && isVerified() && (isAdmin() || isAudit());
      allow create: if isValidId(transferId) && isVerified() && isEmployee() && incoming().fromBranchId == getUserBranchId();
    }

    match /disposals/{disposalId} {
      allow read: if isValidId(disposalId) && isVerified() && (isAdmin() || isAudit());
      allow create: if isValidId(disposalId) && isVerified() && isEmployee() && incoming().branchId == getUserBranchId();
    }
  }
}
